generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model WaitlistEntry {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  collectorType String? // speculator, set-completer, customizer
  collectionSize String? // <50, 50-500, 500+
  createdAt    DateTime @default(now())
}
