generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model WaitlistEntry {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  collectorType String? // speculator, set-completer, customizer
  collectionSize String? // <50, 50-500, 500+
  createdAt    DateTime @default(now())
}
